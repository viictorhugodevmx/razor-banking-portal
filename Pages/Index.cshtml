@page
@model IndexModel

<section class="banking-hero">
    <div>
        <span class="eyebrow">Razor Banking Portal</span>
        <h1>Dashboard financiero</h1>
        <p>
            Portal bancario renderizado con Razor Pages para practicar frontend .NET
            con datos tipo fintech.
        </p>
    </div>
</section>

<section class="dashboard-grid">
    <article class="dashboard-card main-card">
        <span>Cliente</span>
        <h2>@Model.Account.CustomerName</h2>
        <p>@Model.Account.AccountNumber</p>
    </article>

    <article class="dashboard-card">
        <span>Saldo disponible</span>
        <h2>@Model.Account.AvailableBalance.ToString("N2") @Model.Account.Currency</h2>
        <p>Balance actualizado al momento</p>
    </article>

    <article class="dashboard-card">
        <span>Transferencias pendientes</span>
        <h2>@Model.Account.PendingTransfers</h2>
        <p>Operaciones por revisar</p>
    </article>

    <article class="dashboard-card">
        <span>Nivel de riesgo</span>
        <h2>@Model.Account.RiskLevel</h2>
        <p>Evaluación operativa inicial</p>
    </article>
</section>

<section class="movements-section">
    <div class="section-heading">
        <span class="eyebrow dark">Actividad reciente</span>
        <h2>Últimos movimientos</h2>
    </div>

    <div class="movement-list">
        @foreach (var movement in Model.RecentMovements)
        {
            <article class="movement-row">
                <div>
                    <span class="movement-type">@movement.Type</span>
                    <h3>@movement.Description</h3>
                    <p>@movement.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</p>
                </div>

                <strong>@movement.Amount.ToString("N2") @movement.Currency</strong>
            </article>
        }
    </div>
</section>
