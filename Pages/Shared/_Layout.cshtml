@using RazorBankingPortal.Models

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - razor_banking_portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/razor_banking_portal.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-page="/Index">Razor Banking</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Index", Label = "Dashboard" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Accounts", Label = "Cuentas" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Transfers/New", Label = "Transferir" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Transfers/History", Label = "Historial" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Risk", Label = "Riesgo" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Operations", Label = "Operaciones" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Profile", Label = "Perfil" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Settings", Label = "Configuración" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/About", Label = "About" }' />
                        <partial name="Navigation/_NavLink" model='new NavLinkModel { Page = "/Login", Label = "Login" }' />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer border-top text-muted">
        <div class="container">
            &copy; 2026 - razor_banking_portal - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
